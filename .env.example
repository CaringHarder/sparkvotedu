# Supabase Configuration
# Get these from: Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database Connection Strings
# Get these from: Supabase Dashboard -> Settings -> Database -> Connection string
# DATABASE_URL uses Pooler/Transaction mode (port 6543)
DATABASE_URL=
# DIRECT_URL uses Direct connection (port 5432)
DIRECT_URL=

# Site URL (set to https://sparkvotedu.com in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (REQUIRED for auth emails in production)
# Supabase's built-in email only delivers to project team members.
# You MUST configure a custom SMTP provider in the Supabase Dashboard:
#   Dashboard -> Project Settings -> Authentication -> SMTP Settings
# Recommended: Resend (https://resend.com) - free tier: 3,000 emails/month
#   SMTP Host: smtp.resend.com
#   SMTP Port: 465
#   SMTP User: resend
#   SMTP Password: <your Resend API key>
#   Sender email: noreply@yourdomain.com (domain must be verified in Resend)

# Stripe Billing
# Get from: Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard -> Developers -> Webhooks -> Signing secret
STRIPE_WEBHOOK_SECRET=
# Get from: Stripe Dashboard -> Products -> Price IDs
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_PRO_PLUS_MONTHLY_PRICE_ID=
STRIPE_PRO_PLUS_ANNUAL_PRICE_ID=

# SportsDataIO API
# Get from: SportsDataIO Developer Portal -> My Account -> Subscriptions
SPORTSDATAIO_API_KEY=

# Vercel Cron Authentication
# Generate: openssl rand -hex 32
CRON_SECRET=
